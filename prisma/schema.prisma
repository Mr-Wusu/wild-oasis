

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// Your models remain completely untouched
model User {
  id    String @id @default(cuid())
  email String @unique
  password String
  firstname String
  surname String
  role Role @default(USER)
  cabin Cabin?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
  @@index([email])
  @@index([role])
}

model Cabin {
  id String @id @default(cuid())
  discount Int
  name String @unique
  maxCapacity Int
  numGuard Int
  image String
  userid String? @unique
  regularPrice Int
  description String
  bookings Booking[]
  guest User?  @relation(fields: [userid], references: [id], onDelete: SetNull)
  
  @@map("cabins")
  @@index([name])
}

model Booking {
  id         String   @id @default(cuid())
  cabinId    String
  cabin      Cabin    @relation(fields: [cabinId], references: [id], onDelete: Cascade)
  guestName  String
  email      String
  numGuests  Int
  totalPrice Float
  startDate  DateTime
  endDate    DateTime
  isPaid     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("bookings")
  @@index([cabinId])
  @@index([startDate, endDate])
}

model Settings {
  id                  String   @id @default(cuid())
  minBookingLength    Int   @default(1)
  maxBookingLength    Int   @default(90)
  maxGuestsPerBooking Int   @default(10)
  breakfastPrice      Float @default(15)

  @@map("settings")
}


enum Role {
  ADMIN
  TEST_ADMIN
  USER
}
